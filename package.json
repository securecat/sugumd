{
  "name": "sugumd",
  "version": "1.1.0",
  "private": true,
  "type": "module",
  "description": "Chrome extension that saves the current page as a Markdown file with frontmatter",
  "engines": {
    "node": ">=20.19"
  },
  "scripts": {
    "build": "esbuild src/content/index.js --bundle --format=iife --target=chrome110 --outfile=dist/extract.js",
    "test": "node --test"
  },
  "dependencies": {
    "defuddle": "^0.19.1",
    "turndown": "^7.2.0",
    "turndown-plugin-gfm": "^1.0.2"
  },
  "devDependencies": {
    "esbuild": "^0.25.0",
    "linkedom": "^0.18.13"
  }
}
