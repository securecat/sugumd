{
  "manifest_version": 3,
  "name": "sugumd",
  "version": "1.1.0",
  "description": "Extract the main article from the current page and save it instantly as a Markdown file with frontmatter. One click, one file.",
  "minimum_chrome_version": "110",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "sugumd — Save this page as Markdown",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png"
    }
  },
  "permissions": ["activeTab", "scripting", "downloads", "contextMenus"],
  "background": {
    "service_worker": "src/background/service-worker.js",
    "type": "module"
  }
}
